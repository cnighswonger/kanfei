# Kanfei Weather Station Configuration
# Copy to .env and edit as needed

# Serial port settings (Davis serial stations)
# Linux:   /dev/ttyUSB0  or  /dev/ttyS0
# macOS:   /dev/tty.usbserial-XXXX
# Windows: COM3  (check Device Manager -> Ports)
KANFEI_SERIAL_PORT=/dev/ttyUSB0
KANFEI_BAUD_RATE=2400
KANFEI_SERIAL_TIMEOUT=5.0

# Server settings
KANFEI_HOST=0.0.0.0
KANFEI_PORT=8000

# Polling
KANFEI_POLL_INTERVAL_SEC=5

# Database
KANFEI_DB_PATH=weather.db

# Location (for astronomy and NWS forecasts)
KANFEI_LATITUDE=
KANFEI_LONGITUDE=
KANFEI_ELEVATION_FT=0

# NWS API
KANFEI_NWS_ENABLED=false

# METAR output
KANFEI_METAR_ENABLED=false
KANFEI_METAR_STATION_ID=KWXS

# UI theme (dark, light, classic)
KANFEI_THEME=dark
