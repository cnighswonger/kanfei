# Kanfei Weather Station Configuration
#
# Only settings that must be known before the database is available.
# Everything else (serial port, location, units, features) is configured
# through the Setup Wizard and stored in the database.
#
# Copy to .env and edit as needed. All values have sensible defaults.

# Database path (relative to project root, or absolute)
KANFEI_DB_PATH=kanfei.db

# Web server bind address
KANFEI_HOST=0.0.0.0
KANFEI_PORT=8000
