#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_build:
	cd frontend && npm ci && npm run build

override_dh_auto_install:
	# Backend application
	install -d debian/kanfei/opt/kanfei/backend
	cp -r backend/app debian/kanfei/opt/kanfei/backend/
	cp backend/logger_main.py debian/kanfei/opt/kanfei/backend/
	cp backend/pyproject.toml debian/kanfei/opt/kanfei/backend/
	cp backend/alembic.ini debian/kanfei/opt/kanfei/backend/
	cp -r backend/alembic debian/kanfei/opt/kanfei/backend/

	# Frontend (pre-built dist)
	install -d debian/kanfei/opt/kanfei/frontend
	cp -r frontend/dist debian/kanfei/opt/kanfei/frontend/

	# Configuration
	install -d debian/kanfei/etc/kanfei
	install -m 644 debian/kanfei.conf debian/kanfei/etc/kanfei/kanfei.conf

	# Systemd units
	install -d debian/kanfei/lib/systemd/system
	install -m 644 debian/kanfei-logger.service debian/kanfei/lib/systemd/system/
	install -m 644 debian/kanfei-web.service debian/kanfei/lib/systemd/system/

	# Data directory
	install -d debian/kanfei/var/lib/kanfei

override_dh_auto_test:
	# Skip tests during package build

override_dh_auto_clean:
	rm -rf frontend/dist frontend/node_modules
