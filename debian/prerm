#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop services before removal
        systemctl stop kanfei-web.service kanfei-logger.service 2>/dev/null || true
        systemctl disable kanfei-web.service kanfei-logger.service 2>/dev/null || true
        ;;
esac

#DEBHELPER#
exit 0
