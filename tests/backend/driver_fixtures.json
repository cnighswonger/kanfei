{
  "_comment": "Driver test fixtures. Each entry specifies raw hardware data and expected SI SensorSnapshot output.",

  "ecowitt_basic": {
    "driver": "ecowitt",
    "description": "Ecowitt GW2000 basic reading — all primary sensors",
    "input_format": "livedata_markers",
    "raw_markers": {
      "0x01": 225,
      "0x02": 318,
      "0x06": 45,
      "0x07": 78,
      "0x09": 10132,
      "0x0A": 225,
      "0x0B": 45,
      "0x0C": 67,
      "0x0E": 12,
      "0x10": 254,
      "0x13": 5080,
      "0x16": 8500,
      "0x17": 6
    },
    "expected": {
      "inside_temp": 22.5,
      "outside_temp": 31.8,
      "inside_humidity": 45,
      "outside_humidity": 78,
      "barometer": 1013.2,
      "wind_direction": 225,
      "wind_speed": 4.5,
      "wind_gust": 6.7,
      "rain_rate": 1.2,
      "rain_daily": 25.4,
      "rain_yearly": 508.0,
      "solar_radiation": 850,
      "uv_index": 6.0
    }
  },

  "ecowitt_freezing": {
    "driver": "ecowitt",
    "description": "Ecowitt below-freezing reading",
    "input_format": "livedata_markers",
    "raw_markers": {
      "0x01": 180,
      "0x02": -50,
      "0x06": 55,
      "0x07": 90,
      "0x09": 9800,
      "0x0A": 0,
      "0x0B": 0,
      "0x10": 0
    },
    "expected": {
      "inside_temp": 18.0,
      "outside_temp": -5.0,
      "inside_humidity": 55,
      "outside_humidity": 90,
      "barometer": 980.0,
      "wind_direction": 0,
      "wind_speed": 0.0,
      "rain_daily": 0.0
    }
  },

  "tempest_obs_st": {
    "driver": "tempest",
    "description": "Tempest all-in-one observation — native SI passthrough",
    "input_format": "obs_st",
    "raw_obs": [1711382400, 0.5, 2.3, 4.1, 180, 3, 1013.5, 22.5, 65, 45000, 5.2, 850, 0.1, 0, 15, 3, 2.7, 60],
    "rain_state": {
      "rain_daily_mm": 3.5,
      "rain_yearly_mm": 125.0,
      "rain_rate_mm_hr": 6.0
    },
    "expected": {
      "outside_temp": 22.5,
      "outside_humidity": 65,
      "wind_speed": 2.3,
      "wind_gust": 4.1,
      "wind_direction": 180,
      "solar_radiation": 850,
      "uv_index": 5.2,
      "rain_daily": 3.5,
      "rain_yearly": 125.0,
      "rain_rate": 6.0
    }
  },

  "ambient_wu_format": {
